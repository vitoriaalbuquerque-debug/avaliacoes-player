# Copie este arquivo para ".env" e preencha com valores reais antes de rodar.

# Banco de dados — SQLite por padrão, zero instalação. Pra migrar pro piloto,
# troque só esta linha por uma URL de Postgres gerenciado (ex: Neon ou
# Supabase, ambos têm tier gratuito e não exigem instalar nada localmente).
# O SQLAlchemy cuida do resto — não precisa mudar nenhum código.
DATABASE_URL=sqlite:///./comer_fora.db

# Chave da API do Gemini (Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Usada para transcrição de áudio via Whisper API (https://platform.openai.com)
OPENAI_API_KEY=

# Autenticação simples do painel do gerente — TROCAR por autenticação real
# (login por restaurante) antes de qualquer piloto com dado de cliente real.
MANAGER_API_KEY=troque-esta-chave-antes-do-piloto

# Salt usado para gerar o hash do CPF — nunca guardamos CPF em texto puro.
# Gere um valor aleatório longo e mantenha em segredo (não commitar no git).
CPF_HASH_SALT=troque-este-salt-antes-de-qualquer-dado-real

# Onde os áudios ficam salvos localmente no MVP (trocar por storage de objeto
# tipo S3 antes do piloto — ver TODO no README sobre retenção de dados/LGPD)
AUDIO_STORAGE_DIR=./storage/audio
AUDIO_RETENTION_DAYS=30

# Janela (em minutos) usada para decidir se o cliente "ainda está no local"
# para o alerta de recuperação em tempo real do gerente.
ON_SITE_WINDOW_MINUTES=90
